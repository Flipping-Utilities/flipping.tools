---
interface Props {
	tag: string;
}

const { tag } = Astro.props;

const tagColors: Record<string, string> = {
	free: '#22c55e',
	paid: '#ef4444',
	freemium: '#f59e0b',
	'real-time': '#3b82f6',
	alerts: '#8b5cf6',
	legacy: '#6b7280',
	'price-tracking': '#06b6d4',
	analytics: '#ec4899',
	portfolio: '#14b8a6',
	'discord-bot': '#5865f2'
};

const color = tagColors[tag] || '#888';
---

<span class="tag" style={`--tag-color: ${color}`}>{tag}</span>

<style>
	.tag {
		display: inline-block;
		padding: 0.25rem 0.5rem;
		background: color-mix(in srgb, var(--tag-color) 15%, transparent);
		color: var(--tag-color);
		border-radius: 4px;
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: capitalize;
	}
</style>
