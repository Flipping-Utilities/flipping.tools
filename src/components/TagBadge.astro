---
interface Props {
	tag: string;
}

const { tag } = Astro.props;

const tagColors: Record<string, string> = {
	// Pricing
	free: '#22c55e',
	paid: '#ef4444',
	freemium: '#f59e0b',
	// Features
	alerts: '#8b5cf6',
	analytics: '#ec4899',
	api: '#06b6d4',
	charts: '#3b82f6',
	favorites: '#f472b6',
	planner: '#a855f7',
	portfolio: '#14b8a6',
	recommendations: '#f97316',
	recipes: '#84cc16',
	screener: '#0ea5e9',
	trends: '#6366f1'
};

const color = tagColors[tag] || '#888';
---

<span class="tag" style={`--tag-color: ${color}`}>{tag}</span>

<style>
	.tag {
		display: inline-block;
		padding: 0.25rem 0.5rem;
		background: color-mix(in srgb, var(--tag-color) 15%, transparent);
		color: var(--tag-color);
		border-radius: 4px;
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: capitalize;
	}
</style>
