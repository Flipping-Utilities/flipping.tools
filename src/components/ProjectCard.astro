---
import ComponentIcon from './ComponentIcon.astro';
import TagBadge from './TagBadge.astro';

interface ComponentLinks {
	website?: string;
	discordBot?: string;
	discordServer?: string;
	runelite?: string;
	github?: string;
	mobile?: string;
}

interface Props {
	name: string;
	slug: string;
	tagline: string;
	author: string;
	components: ComponentLinks;
	tags: string[];
}

const { name, slug, tagline, author, components, tags } = Astro.props;

const componentEntries = Object.entries(components).filter(([_, v]) => v) as [keyof ComponentLinks, string][];
---

<article class="project-card">
	<div class="card-header">
		<h2><a href={`/projects/${slug}`}>{name}</a></h2>
		<span class="author">by {author}</span>
	</div>

	<p class="tagline">{tagline}</p>

	{componentEntries.length > 0 && (
		<div class="components">
			{componentEntries.map(([type, href]) => (
				<ComponentIcon type={type} href={href} size="sm" />
			))}
		</div>
	)}

	{tags.length > 0 && (
		<div class="tags">
			{tags.map(tag => <TagBadge tag={tag} />)}
		</div>
	)}

	<a href={`/projects/${slug}`} class="view-details">View Details →</a>
</article>

<style>
	.project-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		transition: border-color 0.2s, transform 0.2s;
	}

	.project-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.card-header h2 {
		font-size: 1.125rem;
		margin: 0;
	}

	.card-header h2 a {
		color: var(--fg);
		text-decoration: none;
	}

	.card-header h2 a:hover {
		color: var(--accent);
	}

	.author {
		color: var(--fg-muted);
		font-size: 0.8125rem;
	}

	.tagline {
		color: var(--fg-muted);
		font-size: 0.9375rem;
		margin: 0;
		line-height: 1.5;
	}

	.components {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.view-details {
		margin-top: auto;
		padding-top: 0.5rem;
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--accent);
	}

	.view-details:hover {
		text-decoration: underline;
	}
</style>
