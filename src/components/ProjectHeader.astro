---
import ComponentIcon from './ComponentIcon.astro';
import TagBadge from './TagBadge.astro';

interface ComponentLinks {
	website?: string;
	discordBot?: string;
	discordServer?: string;
	runelite?: string;
	github?: string;
	mobile?: string;
}

interface Props {
	name: string;
	tagline: string;
	author: string;
	components: ComponentLinks;
	tags: string[];
}

const { name, tagline, author, components, tags } = Astro.props;

const componentEntries = Object.entries(components).filter(([_, v]) => v) as [keyof ComponentLinks, string][];
---

<header class="project-header">
	<div class="header-main">
		<h1>{name}</h1>
		<p class="tagline">{tagline}</p>
		<p class="author">by {author}</p>
	</div>

	{componentEntries.length > 0 && (
		<div class="component-links">
			{componentEntries.map(([type, href]) => (
				<ComponentIcon type={type} href={href} />
			))}
		</div>
	)}

	{tags.length > 0 && (
		<div class="tags">
			{tags.map(tag => <TagBadge tag={tag} />)}
		</div>
	)}
</header>

<style>
	.project-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
	}

	.header-main {
		margin-bottom: 1rem;
	}

	h1 {
		font-size: 2rem;
		color: var(--accent);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.125rem;
		color: var(--fg);
		margin-bottom: 0.25rem;
	}

	.author {
		color: var(--fg-muted);
		font-size: 0.9375rem;
	}

	.component-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
</style>
