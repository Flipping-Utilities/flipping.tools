---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComponentIcon from '../components/ComponentIcon.astro';
import TagBadge from '../components/TagBadge.astro';
import projects from '../data/projects.json';

interface ComponentLinks {
	website?: string;
	discordBot?: string;
	discordServer?: string;
	runelite?: string;
	github?: string;
	mobile?: string;
}

const componentOrder: (keyof ComponentLinks)[] = ['website', 'runelite', 'discordBot', 'discordServer', 'github', 'mobile'];

const platformLabels: Record<string, string> = {
	website: 'Website',
	discordBot: 'Discord Bot',
	discordServer: 'Discord Server',
	runelite: 'RuneLite',
	github: 'GitHub',
	mobile: 'Mobile'
};

// Extract unique platforms and tags
const allPlatforms = new Set<string>();
const allTags = new Set<string>();
projects.forEach(project => {
	Object.keys(project.components).forEach(key => {
		if (project.components[key as keyof ComponentLinks]) {
			allPlatforms.add(key);
		}
	});
	project.tags.forEach(tag => allTags.add(tag));
});

const sortedPlatforms = componentOrder.filter(p => allPlatforms.has(p));
const sortedTags = Array.from(allTags).sort();
---

<BaseLayout title="Home">
	<section class="hero">
		<h1>OSRS Flipping Tools</h1>
		<p>Compare the best Grand Exchange flipping tools for Old School RuneScape. Find margins, track prices, and maximize your GP profits.</p>
	</section>

	<div class="filters">
		<div class="filter-group">
			<span class="filter-label">Platforms:</span>
			<div class="filter-buttons" id="platform-filters">
				<button class="filter-btn active" data-filter="all">All</button>
				{sortedPlatforms.map(platform => (
					<button class="filter-btn" data-filter={platform} data-type="platform">
						{platformLabels[platform]}
					</button>
				))}
			</div>
		</div>

		<div class="filter-group">
			<span class="filter-label">Tags:</span>
			<div class="filter-buttons" id="tag-filters">
				<button class="filter-btn active" data-filter="all">All</button>
				{sortedTags.map(tag => (
					<button class="filter-btn" data-filter={tag} data-type="tag">
						{tag}
					</button>
				))}
			</div>
		</div>
	</div>

	<div class="table-wrapper">
		<table>
			<thead>
				<tr>
					<th>Project</th>
					<th>Description</th>
					<th>Platforms</th>
					<th>Tags</th>
				</tr>
			</thead>
			<tbody id="projects-table">
				{projects.map(project => {
					const components = project.components as ComponentLinks;
					const componentEntries = componentOrder
						.map(key => [key, components[key]] as [keyof ComponentLinks, string | undefined])
						.filter(([_, v]) => v) as [keyof ComponentLinks, string][];
					const platforms = componentEntries.map(([type]) => type).join(',');
					const tags = project.tags.join(',');
					return (
						<tr data-platforms={platforms} data-tags={tags}>
							<td class="project-name">
								<a href={`/projects/${project.slug}`}>{project.name}</a>
								<span class="author">by {project.author}</span>
							</td>
							<td class="description">
								<a href={`/projects/${project.slug}`}>{project.tagline}</a>
							</td>
							<td>
								<span class="platforms-list">
									{componentEntries.map(([type, href]) => (
										<ComponentIcon type={type} href={href} size="sm" />
									))}
								</span>
							</td>
							<td>
								<span class="tags-list">
									{project.tags.map(tag => <TagBadge tag={tag} />)}
								</span>
							</td>
						</tr>
					);
				})}
			</tbody>
		</table>
	</div>

	<p class="no-results" id="no-results" style="display: none;">No projects match your filters.</p>
</BaseLayout>

<script>
	const platformFilters = document.getElementById('platform-filters');
	const tagFilters = document.getElementById('tag-filters');
	const tableBody = document.getElementById('projects-table');
	const noResults = document.getElementById('no-results');

	let activePlatform = 'all';
	let activeTag = 'all';

	function filterProjects() {
		if (!tableBody) return;

		const rows = tableBody.querySelectorAll('tr');
		let visibleCount = 0;

		rows.forEach(row => {
			const platforms = (row.dataset.platforms || '').split(',');
			const tags = (row.dataset.tags || '').split(',');

			const matchesPlatform = activePlatform === 'all' || platforms.includes(activePlatform);
			const matchesTag = activeTag === 'all' || tags.includes(activeTag);

			if (matchesPlatform && matchesTag) {
				(row as HTMLElement).style.display = '';
				visibleCount++;
			} else {
				(row as HTMLElement).style.display = 'none';
			}
		});

		if (noResults) {
			noResults.style.display = visibleCount === 0 ? 'block' : 'none';
		}
	}

	function handleFilterClick(e: Event, filterType: 'platform' | 'tag') {
		const target = e.target as HTMLElement;
		if (!target.classList.contains('filter-btn')) return;

		const container = filterType === 'platform' ? platformFilters : tagFilters;
		container?.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
		target.classList.add('active');

		if (filterType === 'platform') {
			activePlatform = target.dataset.filter || 'all';
		} else {
			activeTag = target.dataset.filter || 'all';
		}

		filterProjects();
	}

	platformFilters?.addEventListener('click', (e) => handleFilterClick(e, 'platform'));
	tagFilters?.addEventListener('click', (e) => handleFilterClick(e, 'tag'));
</script>

<style>
	.hero {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	.hero h1 {
		font-size: 2rem;
		color: var(--accent);
		margin-bottom: 0.75rem;
	}

	.hero p {
		color: var(--fg-muted);
		font-size: 1rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.filters {
		margin-bottom: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.filter-group {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.filter-label {
		color: var(--fg-muted);
		font-size: 0.875rem;
		font-weight: 500;
		min-width: 70px;
		padding-top: 0.25rem;
	}

	.filter-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.filter-btn {
		padding: 0.25rem 0.625rem;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--fg-muted);
		font-size: 0.8125rem;
		cursor: pointer;
		transition: all 0.2s;
		text-transform: capitalize;
	}

	.filter-btn:hover {
		border-color: var(--fg-muted);
		color: var(--fg);
	}

	.filter-btn.active {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}

	.table-wrapper {
		overflow-x: auto;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		background: var(--bg-card);
		border-radius: var(--radius);
		overflow: hidden;
	}

	thead {
		background: var(--bg-elevated);
	}

	th {
		text-align: left;
		padding: 1rem;
		font-weight: 600;
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--fg-muted);
		border-bottom: 1px solid var(--border);
	}

	td {
		padding: 0.875rem 1rem;
		border-bottom: 1px solid var(--border);
		vertical-align: middle;
	}

	tr:last-child td {
		border-bottom: none;
	}

	tr:hover {
		background: var(--bg-elevated);
	}

	.project-name a {
		display: block;
		font-weight: 600;
		color: var(--fg);
		text-decoration: none;
	}

	.project-name a:hover {
		color: var(--accent);
	}

	.author {
		display: block;
		font-size: 0.8125rem;
		color: var(--fg-muted);
		margin-top: 0.125rem;
	}

	.description a {
		color: var(--fg-muted);
		text-decoration: none;
		font-size: 0.9375rem;
	}

	.description a:hover {
		color: var(--fg);
	}

	.platforms-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.tags-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
	}

	.no-results {
		text-align: center;
		color: var(--fg-muted);
		padding: 2rem;
		background: var(--bg-card);
		border-radius: var(--radius);
	}

	@media (max-width: 768px) {
		.hero h1 {
			font-size: 1.5rem;
		}

		.filter-group {
			flex-direction: column;
			gap: 0.5rem;
		}

		.filter-label {
			padding-top: 0;
		}

		th, td {
			padding: 0.75rem;
		}

		td:nth-child(4),
		th:nth-child(4) {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.platforms-list {
			flex-direction: column;
		}
	}
</style>
